# Copy this file to `.env` and fill in real values.
# On Railway, set these in the service's Variables tab instead — do not commit .env.

# Google Gemini (required — server fails to boot without this)
GOOGLE_API_KEY=

# Internal API auth header expected by Roblox->backend calls
BLOOM_API_KEY=

# Supabase (optional — if unset, DB writes are skipped with a warning)
SUPABASE_URL=
SUPABASE_KEY=

# Roblox Open Cloud (required for /api/moderate to message Roblox users)
ROBLOX_PLATFORM_API_KEY=
ROBLOX_UNIVERSE_ID=

# Hugging Face Inference (required for PII + content moderation + sentiment models)
HF_TOKEN=

# PORT is auto-injected by Railway. Only set locally if you want a non-default port.
# PORT=8000
